    <w:p w14:paraId="1862D842">
      <w:r>
        <w:rPr>
          <w:i/>
          <w:iCs/>
        </w:rPr>
        <w:t>Trong kỷ nguyên số, AI không chỉ là công cụ mà còn là người trợ lý đắc lực, giúp chúng ta giải phóng thời gian khỏi những công việc lặp đi lặp lại và tập trung vào những giá trị cốt lõi. Khóa học này được thiết kế dành riêng cho người đi làm, với mục tiêu mang lại hiệu quả tức thì và tính ứng dụng cao.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="30AEAB11">
      <w:r>
        <w:t>Hãy chuẩn bị sẵn sàng để khám phá những tiềm năng vô hạn của bản thân khi được trợ lực bởi AI!</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="172A736D"/>
    <w:p w14:paraId="64B5AB89">
      <w:pPr>
        <w:pStyle w:val="2"/>
      </w:pPr>
      <w:r>
        <w:t>GIÁ TRỊ BUỔI HỌC (PHẦN 1)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5567E5F0">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>1. Nắm Bắt Công Cụ AI Hàng Đầu</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="696B6A7B">
      <w:r>
        <w:t>Học viên sẽ được hướng dẫn thực chiến cách ứng dụng các công cụ AI và AI Agent phổ biến và mạnh mẽ nhất hiện nay:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7CEEA5DD">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t xml:space="preserve">Google Gemini Pro: </w:t>
      </w:r>
      <w:r>
        <w:t>Sử dụng Gemini để tạo ra nội dung sáng tạo, phân tích dữ liệu, và giải quyết các bài toán phức tạp hàng ngày.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="38532A1C">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t xml:space="preserve">Google Antigravity: </w:t>
      </w:r>
      <w:r>
        <w:t>Trải nghiệm sức mạnh của agentic AI để tự động hóa những chuỗi quy trình làm việc kéo dài.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="264947B4">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t xml:space="preserve">NotebookLM: </w:t>
      </w:r>
      <w:r>
        <w:t>Khai thác sức mạnh của trợ lý nghiên cứu cá nhân, phân tích và tóm tắt một lượng lớn tài liệu, báo cáo nhanh chóng.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="221AE573">
      <w:pPr>
        <w:spacing w:before="400"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="71E2B740">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>2. Tự Động Hóa Công Việc</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3F14E491">
      <w:r>
        <w:t>Một trong những giá trị cốt lõi là khả năng tự động hóa, giúp bạn giảm tải tác vụ lặp đi lặp lại:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3FC93BA6">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Tổng hợp tin tức và yêu cầu tuyển dụng một cách nhanh chóng và chính xác nhất.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="77620E8D">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Soạn thảo CV và thư xin việc chuyên nghiệp, ấn tượng, may đo phù hợp với từng vị trí công việc cụ thể.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3915AD90">
      <w:pPr>
        <w:spacing w:before="400" w:after="200"/>
        <w:jc w:val="center"/>
      </w:pPr>
      <w:r>
        <w:drawing>
          <wp:inline distT="0" distB="0" distL="0" distR="0">
            <wp:extent cx="3810000" cy="3810000"/>
            <wp:effectExtent l="0" t="0" r="0" b="0"/>
            <wp:docPr id="2" name="Vibe Coding" descr="Vibe Coding" title="Vibe Coding"/>
            <wp:cNvGraphicFramePr>
              <a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/>
            </wp:cNvGraphicFramePr>
            <a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main">
              <a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture">
                <pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture">
                  <pic:nvPicPr>
                    <pic:cNvPr id="2" name="Vibe Coding" descr="Vibe Coding" title="Vibe Coding"/>
                    <pic:cNvPicPr>
                      <a:picLocks noChangeAspect="1" noChangeArrowheads="1"/>
                    </pic:cNvPicPr>
                  </pic:nvPicPr>
                  <pic:blipFill>
                    <a:blip r:embed="rId6"/>
                    <a:srcRect/>
                    <a:stretch>
                      <a:fillRect/>
                    </a:stretch>
                  </pic:blipFill>
                  <pic:spPr>
                    <a:xfrm>
                      <a:off x="0" y="0"/>
                      <a:ext cx="3810000" cy="3810000"/>
                    </a:xfrm>
                    <a:prstGeom prst="rect">
                      <a:avLst/>
                    </a:prstGeom>
                  </pic:spPr>
                </pic:pic>
              </a:graphicData>
            </a:graphic>
          </wp:inline>
        </w:drawing>
      </w:r>
    </w:p>
    <w:p w14:paraId="5396C485"/>
    <w:p w14:paraId="3C17A215">
      <w:pPr>
        <w:pStyle w:val="2"/>
      </w:pPr>
      <w:r>
        <w:t>GIÁ TRỊ BUỔI HỌC (PHẦN 2)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="20E8E99A">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>3. Vibe Coding Đỉnh Cao</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1337B3BB">
      <w:r>
        <w:t>Đây là một trong những nội dung độc quyền và hấp dẫn nhất của chương trình. Không cần có kiến thức nền tảng về lập trình, bạn vẫn có thể tự tạo ra các sản phẩm công nghệ ấn tượng:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="278DE12E">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Từ tài liệu có sẵn, sử dụng AI để sinh mã nguồn (code) hoàn toàn tự động.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="715E5E05">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:bookmarkStart w:id="0" w:name="_GoBack"/>
      <w:r>
        <w:t>Tạo ngay một App thi trắc nghiệm hoàn chỉnh, có giao diện đẹp mắt và logic hoạt động chuẩn xác một cách dễ dàng và nhanh chóng.</w:t>
      </w:r>
    </w:p>
<w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0"><wp:extent cx="3600000" cy="3600000"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="100" name="Picture"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId9"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:ext cx="3600000" cy="3600000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p>
    <w:bookmarkEnd w:id="0"/>
    <w:p w14:paraId="33E81883">
      <w:pPr>
        <w:spacing w:before="400"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="53F200BB">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>4. Tối Ưu Quy Trình và Tư Duy</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1B806CBF">
      <w:r>
        <w:t>Bên cạnh việc sử dụng công cụ, khóa học còn giúp bạn phát triển tư duy làm việc hiệu suất cao:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6E5A0453">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Tối ưu quy trình: Tự động viết báo cáo dự án chi tiết, trình bày số liệu rõ ràng ngay sau khi hoàn thành App.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="68FD26B8">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Sở hữu công thức giao tiếp với AI hiệu quả (Prompt Engineering) để đưa ra yêu cầu sắc bén và nhận về kết quả chính xác.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6FD4C4AA">
      <w:pPr>
        <w:pStyle w:val="16"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Xây dựng tư duy ứng dụng AI tối ưu để tạo lợi thế cạnh tranh vượt trội trên con đường phát triển sự nghiệp.</w:t>
      </w:r>
    </w:p>
<w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0"><wp:extent cx="3600000" cy="3600000"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="101" name="Picture"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId10"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:ext cx="3600000" cy="3600000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p>
    <w:p w14:paraId="046B4458">
      <w:r>
        <w:br w:type="page"/>
      </w:r>
    </w:p>
    <w:p w14:paraId="0649A213">
      <w:pPr>
        <w:pStyle w:val="2"/>
      </w:pPr>
      <w:r>
        <w:t>THÔNG TIN CHI TIẾT</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="03EECE5C">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>Đội ngũ giảng viên (Trainer)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="169B4222">
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>Nguyễn Đức Hoàng</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="675F72B2">
      <w:r>
        <w:t>Chuyên gia đào tạo AI và phát triển phần mềm hàng đầu tại VietIS Education. Thầy Hoàng đã có nhiều năm kinh nghiệm trong việc áp dụng AI vào quy trình sản xuất phần mềm thực tế và đào tạo cho hàng trăm kỹ sư, nhân sự phi công nghệ đạt hiệu quả cao.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="02E56CFF">
      <w:pPr>
        <w:pStyle w:val="3"/>
      </w:pPr>
      <w:r>
        <w:t>Thông tin tổ chức (Logistics)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="037B4EE3">
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>Thời gian:</w:t>
      </w:r>
      <w:r>
        <w:t xml:space="preserve"> (Sẽ cập nhật thời gian cụ thể tới từng học viên đã đăng ký)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6E87E096">
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>Hình thức học:</w:t>
      </w:r>
      <w:r>
        <w:t xml:space="preserve"> Online qua Zoom - Tương tác trực tiếp cùng giảng viên.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5887B6FD">
      <w:pPr>
        <w:spacing w:before="600"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="0ED49553">
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
          <w:color w:val="0066FF"/>
        </w:rPr>
        <w:t>Lời kết:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="74E1DA3C">
      <w:r>
        <w:rPr>
          <w:i/>
          <w:iCs/>
